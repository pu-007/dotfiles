#compdef wots

autoload -U is-at-least

_wots() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-h[Print help]' \
'--help[Print help]' \
":: :_wots_commands" \
"*::: :->wots" \
&& ret=0
    case $state in
    (wots)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:wots-command-$line[1]:"
        case $line[1] in
            (create)
_arguments "${_arguments_options[@]}" : \
'-a+[Custom app name.]:APP_NAME:_default' \
'--app-name=[Custom app name.]:APP_NAME:_default' \
'-t+[Package type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--type=[Package type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--no-stow[Skip stow after creation.]' \
'--no-sync[Skip Windows sync after creation.]' \
'-n[Preview only.]' \
'--dry-run[Preview only.]' \
'-y[Skip confirmation prompts.]' \
'--yes[Skip confirmation prompts.]' \
'-h[Print help]' \
'--help[Print help]' \
'*::sources -- Source file(s) or dir(s).:_default' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'-t+[Only sync this type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--type=[Only sync this type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--app=[Sync only a specific package.]:APP:_default' \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-n[Preview only.]' \
'--dry-run[Preview only.]' \
'--bypass[Skip root confirmation.]' \
'-y[Skip confirmation prompts.]' \
'--yes[Skip confirmation prompts.]' \
'-q[Minimal output.]' \
'--quiet[Minimal output.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-j[JSON output.]' \
'--json[JSON output.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-t+[Filter by type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--type=[Filter by type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-j[JSON output.]' \
'--json[JSON output.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'-t+[Filter by type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--type=[Filter by type]:PKG_TYPE:(user config local root meta winuser winconfig winlocal winroaming)' \
'--app=[Show diff for a specific package.]:APP:_default' \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-j[JSON output.]' \
'--json[JSON output.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-u+[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'--win-user=[Windows username (required for Windows package sync). Also settable via WIN_USER env var.]:WIN_USER:_default' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell:(bash zsh fish)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_wots_commands] )) ||
_wots_commands() {
    local commands; commands=(
'create:Create a new package from existing files' \
'sync:Force-copy packages to their targets' \
'stats:Show repository statistics' \
'list:List all packages with details' \
'diff:Show file differences between repo and targets' \
'completion:Generate shell completion script' \
    )
    _describe -t commands 'wots commands' commands "$@"
}
(( $+functions[_wots__subcmd__completion_commands] )) ||
_wots__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'wots completion commands' commands "$@"
}
(( $+functions[_wots__subcmd__create_commands] )) ||
_wots__subcmd__create_commands() {
    local commands; commands=()
    _describe -t commands 'wots create commands' commands "$@"
}
(( $+functions[_wots__subcmd__diff_commands] )) ||
_wots__subcmd__diff_commands() {
    local commands; commands=()
    _describe -t commands 'wots diff commands' commands "$@"
}
(( $+functions[_wots__subcmd__list_commands] )) ||
_wots__subcmd__list_commands() {
    local commands; commands=()
    _describe -t commands 'wots list commands' commands "$@"
}
(( $+functions[_wots__subcmd__stats_commands] )) ||
_wots__subcmd__stats_commands() {
    local commands; commands=()
    _describe -t commands 'wots stats commands' commands "$@"
}
(( $+functions[_wots__subcmd__sync_commands] )) ||
_wots__subcmd__sync_commands() {
    local commands; commands=()
    _describe -t commands 'wots sync commands' commands "$@"
}

if [ "$funcstack[1]" = "_wots" ]; then
    _wots "$@"
else
    compdef _wots wots
fi
